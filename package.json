{
  "name": "@tiaohsun/vue-datatable",
  "author": "tiaohsun",
  "version": "3.0.0",
  "description": "A self-contained Vue 3 data table (Tailwind 4-styled, no Tailwind install required) with dark mode, i18n, sorting and selection.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tiaohsun31/vue-datatable.git"
  },
  "homepage": "https://github.com/Tiaohsun31/vue-datatable#readme",
  "bugs": {
    "url": "https://github.com/Tiaohsun31/vue-datatable/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./style.css": {
      "import": "./dist/vue-datatable.css",
      "require": "./dist/vue-datatable.css"
    }
  },
  "style": "./dist/vue-datatable.css",
  "files": [
    "dist"
  ],
  "keywords": [
    "vue3",
    "vue-component",
    "datatable",
    "data-table",
    "table",
    "tailwindcss",
    "dark-mode",
    "i18n"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only && npm run build:types",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "1.6.20",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  }
}
